# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.example` is committed as a template.

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- CORS (comma-separated origins, no trailing slash) ---
CORS_ORIGINS=http://localhost:5173

# --- Sport (MVP ships with boxing; see plan.md Stretch goal 1 for UFC) ---
DEFAULT_SPORT=boxing

# --- Paths (relative to server/) ---
MODEL_PATH=models/boxing_predictor.pkl
PROCESSED_DATA_PATH=data/processed/fights.csv
